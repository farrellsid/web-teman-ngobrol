---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const pillars = [
  {
    icon: '🌍',
    title: 'Info Kuliah Luar Negeri',
    desc: 'Dari biaya kuliah, biaya hidup, sampai proses visa — kami kumpulkan informasinya agar kamu bisa fokus mempersiapkan diri.',
  },
  {
    icon: '🎓',
    title: 'Panduan Beasiswa',
    desc: 'Kami bantu kamu memahami berbagai jalur beasiswa: LPDP, Erasmus, DAAD, dan banyak lagi — dengan penjelasan yang mudah dicerna.',
  },
  {
    icon: '🤝',
    title: 'Cerita dari Sesama',
    desc: 'Tips dari mahasiswa yang sudah merasakannya sendiri. Pengalaman nyata dari berbagai negara, jurusan, dan latar belakang.',
  },
];

const testimonials = [
  {
    quote: 'Berkat konten Teman Ngobrol, saya jadi jauh lebih siap sebelum apply ke universitas di Jerman. Informasinya detail dan gampang dipahami.',
    name: 'Anisa R.',
    role: 'Mahasiswa S2 di Berlin, Jerman',
  },
  {
    quote: 'Artikel soal biaya hidup di berbagai negara sangat membantu saya menentukan negara tujuan. Akhirnya pilih Belanda dan tidak menyesal!',
    name: 'Bima S.',
    role: 'Mahasiswa S1 di Delft, Belanda',
  },
  {
    quote: 'Panduan beasiswanya lengkap banget. Saya berhasil dapat LPDP setelah baca dan ikutin tips dari Teman Ngobrol.',
    name: 'Citra M.',
    role: 'Awardee LPDP, studi di Melbourne',
  },
];
---

<!doctype html>
<html lang="id">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-[#FFFBDC]">
    <Header />

    <main>
      <!-- ─── HERO ─── -->
      <section class="relative overflow-hidden bg-gradient-to-br from-[#FFFBDC] via-[#FFD3A5] to-[#FFAA6E]">
        <div class="max-w-5xl mx-auto px-6 py-24 md:py-36 text-center">
          <p class="font-body text-sm font-semibold uppercase tracking-widest text-[#FF5900] mb-4">
            Komunitas Mahasiswa · Kuliah ke Luar Negeri
          </p>
          <h1 class="font-display text-4xl md:text-6xl font-bold text-gray-900 leading-tight mb-6">
            Kuliah ke Luar Negeri?<br class="hidden md:block" /> Mulai dari Sini.
          </h1>
          <p class="font-body text-lg md:text-xl text-gray-700 max-w-2xl mx-auto mb-10 leading-relaxed">
            Teman Ngobrol hadir untuk menemani perjalanan studi ke luar negeri kamu — dari riset negara tujuan, cari beasiswa, sampai tips bertahan hidup di perantauan.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="/articles"
              class="inline-block bg-[#FF8237] hover:bg-[#FF5900] text-white font-body font-bold px-8 py-4 rounded-full text-base transition-colors no-underline shadow-lg shadow-orange-200"
            >
              Baca Artikel →
            </a>
            <a
              href="https://instagram.com/temanngobrol"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block bg-white/70 hover:bg-white text-[#FF5900] font-body font-bold px-8 py-4 rounded-full text-base transition-colors no-underline border border-[#FFAA6E]"
            >
              Ikuti di Instagram
            </a>
          </div>
        </div>

        <!-- decorative blobs -->
        <div class="absolute -top-20 -right-20 w-72 h-72 bg-[#FF8237]/20 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
        <div class="absolute -bottom-16 -left-16 w-56 h-56 bg-[#FFD3A5]/40 rounded-full blur-2xl pointer-events-none" aria-hidden="true"></div>
      </section>

      <!-- ─── WHAT WE DO ─── -->
      <section class="bg-[#FFFBDC] py-20 px-6">
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-14">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900 mb-4">
              Apa yang Kami Bagikan
            </h2>
            <p class="font-body text-gray-600 max-w-xl mx-auto">
              Teman Ngobrol bukan agen kuliah — kami komunitas mahasiswa yang berbagi informasi jujur dan pengalaman nyata tentang studi ke luar negeri.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {pillars.map((p) => (
              <div class="bg-white rounded-2xl p-8 shadow-sm border border-[#FFD3A5]/50 hover:shadow-md hover:-translate-y-1 transition-all">
                <div class="text-4xl mb-5">{p.icon}</div>
                <h3 class="font-display text-xl font-bold text-gray-900 mb-3">{p.title}</h3>
                <p class="font-body text-gray-600 leading-relaxed text-sm">{p.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ─── TESTIMONIALS ─── -->
      <section class="bg-[#FFD3A5]/30 py-20 px-6">
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-14">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900 mb-4">
              Kata Mereka
            </h2>
            <p class="font-body text-gray-600">
              Dari teman-teman yang sudah berhasil kuliah ke luar negeri.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {testimonials.map((t) => (
              <figure class="bg-white rounded-2xl p-8 shadow-sm border border-[#FFD3A5]/50 flex flex-col">
                <blockquote class="font-body text-gray-700 leading-relaxed text-sm flex-1 mb-6">
                  "{t.quote}"
                </blockquote>
                <figcaption>
                  <p class="font-body font-bold text-gray-900 text-sm">{t.name}</p>
                  <p class="font-body text-gray-500 text-xs mt-0.5">{t.role}</p>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>

      <!-- ─── CTA SECTION ─── -->
      <section class="bg-gradient-to-r from-[#FF8237] to-[#FF5900] py-20 px-6">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-5">
            Siap Mulai Perjalananmu?
          </h2>
          <p class="font-body text-white/90 text-lg mb-10 leading-relaxed">
            Ikuti Teman Ngobrol dan dapatkan informasi terbaru seputar kuliah ke luar negeri — dari negara tujuan, beasiswa, sampai cerita kehidupan di perantauan.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="/articles"
              class="inline-block bg-white text-[#FF5900] font-body font-bold px-8 py-4 rounded-full text-base transition-colors hover:bg-[#FFFBDC] no-underline shadow-lg"
            >
              Jelajahi Artikel
            </a>
            <a
              href="https://instagram.com/temanngobrol"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block bg-transparent border-2 border-white text-white font-body font-bold px-8 py-4 rounded-full text-base transition-colors hover:bg-white/10 no-underline"
            >
              Ikuti di Instagram
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
