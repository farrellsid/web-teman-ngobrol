---
import site from '../../data/site.json';
const { text, pillars } = site.about;
---
<section class="px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-5xl">
    <div class="max-w-2xl">
      <h2 class="font-display text-3xl font-bold tracking-tight text-brand-terracotta sm:text-4xl">
        Apa itu Teman Ngobrol?
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-brand-ink">{text}</p>
    </div>
    <ul class="mt-12 border-t border-brand-terracotta/15">
      {pillars.map((p) => (
        <li class="flex gap-4 border-b border-brand-terracotta/15 py-6">
          <span aria-hidden="true" class="mt-2.5 h-2.5 w-2.5 shrink-0 rounded-full bg-brand-ember"></span>
          <div>
            <h3 class="font-display text-xl font-semibold text-brand-ink sm:text-2xl">{p.title}</h3>
            <p class="mt-1 text-brand-muted">{p.text}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
