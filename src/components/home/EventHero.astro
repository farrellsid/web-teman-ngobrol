---
import site from '../../data/site.json';
const { name, date, description, posterImage } = site.event;
---
<section class="px-6 pt-16 pb-16 sm:pt-24 sm:pb-20">
  <div class="mx-auto max-w-5xl">
    <p class="text-sm font-semibold tracking-wide text-brand-muted">{date}</p>
    <h1 class="mt-3 font-display text-6xl font-extrabold leading-[0.98] tracking-tight text-brand-ink sm:text-7xl">
      {name}<span class="text-brand-ember">.</span>
    </h1>
    <p class="mt-6 max-w-2xl text-xl leading-relaxed text-brand-ink">{description}</p>
    <a href="/daftar"
       class="mt-8 inline-block rounded-full bg-brand-ember px-8 py-4 font-display text-lg font-bold text-brand-ink transition-transform hover:-translate-y-0.5">
      Daftar sekarang <span aria-hidden="true">→</span>
    </a>
    {posterImage && (
      <img src={posterImage} alt={`Poster ${name}`} width="1200" height="630"
           class="mt-12 w-full rounded-3xl object-cover" />
    )}
  </div>
</section>
