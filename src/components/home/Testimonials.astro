---
import { getCollection } from 'astro:content';
const testimonials = await getCollection('testimonials');
---
<section class={`bg-brand-peach/50 px-6 ${testimonials.length > 0 ? 'py-16 sm:py-24' : 'py-12'}`}>
  <div class="mx-auto max-w-5xl">
    <h2 class="font-display text-3xl font-bold tracking-tight text-brand-terracotta sm:text-4xl">Testimoni</h2>
    {testimonials.length > 0 ? (
      <div class="mt-10 grid gap-10 sm:grid-cols-2">
        {testimonials.map((t) => (
          <figure>
            <blockquote class="font-display text-xl font-medium leading-snug text-brand-ink sm:text-2xl">
              &ldquo;{t.data.quote}&rdquo;
            </blockquote>
            <figcaption class="mt-4 text-sm font-semibold text-brand-terracotta">
              {t.data.name}{t.data.cohort ? `, ${t.data.cohort}` : ''}
            </figcaption>
          </figure>
        ))}
      </div>
    ) : (
      <p class="mt-4 text-lg text-brand-muted">Testimoni akan segera hadir.</p>
    )}
  </div>
</section>
