---
import site from '../data/site.json';
const year = new Date().getFullYear();
---
<footer class="bg-brand-clay text-brand-cream">
  <div class="mx-auto grid max-w-6xl gap-8 px-6 py-12 sm:grid-cols-3">
    <div>
      <p class="font-display text-xl font-extrabold lowercase">teman ngobrol<span class="text-brand-ember">.</span></p>
      <p class="mt-2 max-w-xs text-sm text-brand-cream/75">{site.tagline}</p>
    </div>
    <nav class="text-sm">
      <p class="mb-2 font-semibold">Tautan</p>
      <ul class="space-y-1.5">
        <li><a class="text-brand-cream/80 hover:text-brand-cream" href="/about">Tentang</a></li>
        <li><a class="text-brand-cream/80 hover:text-brand-cream" href="/articles">Artikel</a></li>
        <li><a class="text-brand-cream/80 hover:text-brand-cream" href="/daftar">Daftar event</a></li>
      </ul>
    </nav>
    <div class="text-sm">
      <p class="mb-2 font-semibold">Ikuti</p>
      <a class="text-brand-cream/80 hover:text-brand-cream" href={site.instagramUrl} target="_blank" rel="noopener noreferrer">Instagram</a>
    </div>
  </div>
  <div class="border-t border-brand-cream/10 py-4 text-center text-xs text-brand-cream/60">
    &copy; {year} Teman Ngobrol
  </div>
</footer>
